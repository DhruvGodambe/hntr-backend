# hntr-backend environment configuration.
# Copy this file to `.env` and fill in real values before running the server.
#
# NOTE: src/config/env.ts also auto-loads ../hntr/.env first, so USDT_ADDRESS,
# USDC_ADDRESS and SEPOLIA_RPC_URL are already inherited from the contracts
# workspace's .env if you deployed from there - you only need to duplicate
# them here if you want this backend to point somewhere different.

PORT=8000
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/hntr

# RPC endpoint for the chain the contract is deployed on
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# HNTRMembership contract address (from `forge script ... --broadcast` output)
CONTRACT_ADDRESS=

# Only needed if this backend should use different tokens than hntr/.env
USDT_ADDRESS=
USDC_ADDRESS=

# Long random string used to sign session JWTs. REQUIRED in production.
JWT_SECRET=change-me-to-a-long-random-string

# Session/nonce lifetimes (seconds)
AUTH_TOKEN_TTL_SECONDS=86400
AUTH_NONCE_TTL_SECONDS=300

# Etherscan v2 unified API - used instead of raw eth_getLogs for historical event
# queries, since most public RPC nodes reject eth_getLogs over any non-trivial
# block range ("Archive requests require a personal token"). Already inherited
# from hntr/.env if you deployed from there.
ETHERSCAN_API_KEY=
ETHERSCAN_CHAIN_ID=11155111
# Block the contract was deployed at, to avoid scanning from block 0 (from the
# `forge script ... --broadcast` output).
CONTRACT_DEPLOY_BLOCK=0

# Private key that controls `leadershipWallet` on-chain (from `npm run generate:wallets`
# -> generated-wallets.env). Required for the monthly leadership-pool payout cron
# (src/jobs/leadership-cron.ts) to actually transfer each eligible user's share.
LEADERSHIP_PRIVATE_KEY=

# Private key that controls `achievementWallet` on-chain. Required for the daily
# rank-achievement bonus cron to auto-deposit one-time PDF bonuses when funded.
ACHIEVEMENT_WALLET_PRIVATE_KEY=

# Private key that controls `companyWallet` on-chain. Required for the backend to
# sign purchase/upgrade commission auth (uplines + ranks), query overdue wallets,
# and execute company-wallet withdrawals on behalf of users.
COMPANY_WALLET_PRIVATE_KEY=

# Shared secret required (via an `x-admin-secret` header) to call protected
# /api/admin routes that move real funds, e.g. POST /api/admin/run-leadership-payout
# or POST /api/admin/run-achievement-payout. Leave empty to keep those routes disabled.
ADMIN_SECRET=
